# =============================================================================
# PNW Repair Uploader — environment configuration
# Copy to .env.local for local dev. In production, set these as GitHub Actions
# repo variables/secrets (they are baked into the static bundle at build time).
# NOTE: nothing here is a secret in the SPA sense — a public client (PKCE) has
# no client secret. The client ID and tenant ID are safe to ship in the bundle.
# =============================================================================

# Mock mode: when "false", the app talks to real Microsoft Graph. Anything
# else (or unset) keeps the app on built-in mock data so you can develop the
# UI without an Entra app registration or SharePoint access.
VITE_USE_MOCK=true

# --- Entra ID (Azure AD) app registration ---------------------------------
# From the app registration's Overview page.
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=

# --- SharePoint target ------------------------------------------------------
# Site ID in the composite form Graph returns:
#   {hostname},{site-collection-guid},{web-guid}
VITE_SP_SITE_ID=

# Optional: target a specific document library (drive) by its drive ID. If
# unset, the app uses the site's default drive ("Documents"/"Shared Documents").
VITE_SP_DRIVE_ID=

# Optional: a folder path (relative to the drive root) to scope the app to.
# e.g. "Repairs/Intake". If unset, the app starts at the drive root and shows
# whatever folders the service account can see. Real access is enforced by
# SharePoint item-level permissions on the service account, NOT by this value.
VITE_SP_ROOT_FOLDER=

# --- GitHub Pages -----------------------------------------------------------
# Production base path = "/<repo-name>/". Set once the repo exists, e.g.
# "/pnw-repair-uploader/". Leave blank for a user/org root site.
VITE_BASE_PATH=
